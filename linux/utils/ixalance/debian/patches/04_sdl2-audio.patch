+/* ---- audio callback (runs in SDL audio thread) ------------------------- */
+static void audio_callback(void *userdata, Uint8 *stream, int len) {
+    int16_t *out   = (int16_t *)stream;
+    size_t  frames = (size_t)len / (2 * sizeof(int16_t));
+    (void)userdata;
+    SDL_LockMutex(audio_mutex);
+    if (openmpt_mod) {
+        size_t read = openmpt_module_read_interleaved_stereo(
+            openmpt_mod, (int32_t)audio_spec.freq, frames, out);
+        if (read < frames)
+            memset(out + read * 2, 0, (frames - read) * 4);
+    } else {
+        memset(stream, 0, (size_t)len);
+    }
+    SDL_UnlockMutex(audio_mutex);
 }
 
-void IXSND_SoundSetup(void) {
-    /* MIDASconfig(); */
+/* ---- audio helpers ----------------------------------------------------- */
+static int audio_init(void) {
+    SDL_AudioSpec want;
+    if (SDL_InitSubSystem(SDL_INIT_AUDIO) < 0) return 0;
+    audio_mutex = SDL_CreateMutex();
+    if (!audio_mutex) return 0;
+    SDL_zero(want);
+    want.freq     = 44100;
+    want.format   = AUDIO_S16SYS;
+    want.channels = 2;
+    want.samples  = 512;
+    want.callback = audio_callback;
+    audio_dev = SDL_OpenAudioDevice(NULL, 0, &want, &audio_spec, 0);
+    if (!audio_dev) return 0;
+    SDL_PauseAudioDevice(audio_dev, 0);
+    return 1;
+}
+
+static void audio_load_from_memory(const void *data, size_t size) {
+    openmpt_module *new_mod;
+    if (!data || !size) return;
+    new_mod = openmpt_module_create_from_memory2(
+        data, size,
+        openmpt_log_func_silent,  NULL,
+        openmpt_error_func_ignore, NULL,
+        NULL, NULL, NULL);
+    if (!new_mod) return;
+    SDL_LockMutex(audio_mutex);
+    if (openmpt_mod) openmpt_module_destroy(openmpt_mod);
+    openmpt_mod = new_mod;
+    SDL_UnlockMutex(audio_mutex);
+    MIDAS_playing = 1;
+}
+
+static void audio_stop(void) {
+    SDL_LockMutex(audio_mutex);
+    if (openmpt_mod) { openmpt_module_destroy(openmpt_mod); openmpt_mod = NULL; }
+    SDL_UnlockMutex(audio_mutex);
+    MIDAS_playing = 0;
+}
+
+static void audio_suspend(void) { if (audio_dev) SDL_PauseAudioDevice(audio_dev, 1); }
+static void audio_resume(void)  { if (audio_dev) SDL_PauseAudioDevice(audio_dev, 0); }
+
+static void audio_get_position(unsigned char *order, unsigned char *row) {
+    SDL_LockMutex(audio_mutex);
+    if (openmpt_mod) {
+        *order = (unsigned char)openmpt_module_get_current_order(openmpt_mod);
+        *row   = (unsigned char)openmpt_module_get_current_row(openmpt_mod);
+    } else { *order = 0; *row = 0; }
+    SDL_UnlockMutex(audio_mutex);
+}
+
+static void audio_close(void) {
+    audio_stop();
+    if (audio_dev) { SDL_PauseAudioDevice(audio_dev, 1);
+                     SDL_CloseAudioDevice(audio_dev); audio_dev = 0; }
+    if (audio_mutex) { SDL_DestroyMutex(audio_mutex); audio_mutex = NULL; }
 }
 
+void IXSND_SoundInit(void) { /* audio initialised in DemoMain() via audio_init() */ }
+
+void IXSND_SoundSetup(void) { }
