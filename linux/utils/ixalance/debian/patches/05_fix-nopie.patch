---
This patch header follows DEP-3: http://dep.debian.net/deps/dep3/
--- a/Makefile
+++ b/Makefile
@@ -2,8 +2,8 @@
 CC ?= gcc
 CXX ?= g++
 NASM ?= nasm
-CFLAGS += -ffast-math -m32 $(shell sdl2-config --cflags)
-LDFLAGS += -m32 $(shell sdl2-config --libs) -lopenmpt -lm
+CFLAGS += -ffast-math -m32 -fno-pie $(shell sdl2-config --cflags)
+LDFLAGS += -m32 -no-pie $(shell sdl2-config --libs) -lopenmpt -lm
 OBJ =  main.o  lzss.o unrle.o d32load.o code.o
 
 
