This patch header follows DEP-3: http://dep.debian.net/deps/dep3/
--- a/d32load.c
+++ b/d32load.c
@@ -5,6 +5,7 @@
 #include <string.h>
 #include <unistd.h>
 #include <stdint.h>
+#include <sys/mman.h>
 
 #include <SDL2/SDL.h>
 #include <libopenmpt/libopenmpt.h>
@@ -367,6 +368,14 @@
     if (!(exeofs = IXDRV_Malloc(memrequired)))
         IXDRV_OutputDebug("Virtual Alloc (for final exe memory) Failed!\n");
 
+    if (exeofs) {
+        uintptr_t base = (uintptr_t)exeofs & ~(uintptr_t)4095u;
+        size_t    len  = (size_t)memrequired + ((uintptr_t)exeofs & 4095u);
+        len = (len + 4095u) & ~(size_t)4095u;
+        if (mprotect((void *)base, len, PROT_READ | PROT_WRITE | PROT_EXEC) < 0)
+            IXDRV_OutputDebug("mprotect(EXEC) failed for exe buffer\n");
+    }
+
     startip += (uint32_t)(uintptr_t) exeofs;
     startsp += (uint32_t)(uintptr_t) exeofs;
 
