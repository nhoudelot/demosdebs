+// Decode the first UTF-8 codepoint at s[i], advance i past the sequence.
+static FT_ULong utf8NextCodepoint(const std::string& s, size_t& i)
+{
+	unsigned char c = static_cast<unsigned char>(s[i]);
+	FT_ULong cp;
+	size_t extra;
+	if (c < 0x80) {
+		cp = c; extra = 0;
+	} else if ((c & 0xE0) == 0xC0) {
+		cp = c & 0x1F; extra = 1;
+	} else if ((c & 0xF0) == 0xE0) {
+		cp = c & 0x0F; extra = 2;
+	} else {
+		cp = c & 0x07; extra = 3;
+	}
+	for (size_t k = 0; k < extra && i + 1 + k < s.size(); ++k)
+		cp = (cp << 6) | (static_cast<unsigned char>(s[i + 1 + k]) & 0x3F);
+	i += 1 + extra;
+	return cp;
+}
+
+// Return true if byte is a UTF-8 continuation byte (10xxxxxx).
+static bool isUtf8Continuation(unsigned char c)
+{
+	return (c & 0xC0) == 0x80;
+}
