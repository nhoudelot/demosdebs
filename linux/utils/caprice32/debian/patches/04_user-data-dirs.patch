+static std::string getUserDataDir()
+{
+  const char* xdgDataHome = getenv("XDG_DATA_HOME");
+  if (xdgDataHome && xdgDataHome[0])
+    return std::string(xdgDataHome) + "/caprice32";
+  const char* homeDir = getenv("HOME");
+  if (homeDir)
+    return std::string(homeDir) + "/.local/share/caprice32";
+  return "";
+}
+
+// Read an XDG user directory (e.g. XDG_PICTURES_DIR) from the environment
+// or from ~/.config/user-dirs.dirs.  Returns "" if not found.
+static std::string getXdgUserDir(const std::string& varName)
+{
+  const char* envVal = getenv(varName.c_str());
+  if (envVal && envVal[0]) return std::string(envVal);
+
+  const char* homeDir = getenv("HOME");
+  if (!homeDir) return "";
+
+  std::ifstream f(std::string(homeDir) + "/.config/user-dirs.dirs");
+  if (!f.is_open()) return "";
+
+  std::string line;
+  while (std::getline(f, line)) {
+    if (line.empty() || line[0] == '#') continue;
+    const std::string prefix = varName + "=";
+    if (line.substr(0, prefix.size()) != prefix) continue;
+    std::string val = line.substr(prefix.size());
+    // Strip surrounding double-quotes.
+    if (val.size() >= 2 && val.front() == '"' && val.back() == '"')
+      val = val.substr(1, val.size() - 2);
+    // Expand leading $HOME token.
+    const std::string homeToken = "$HOME";
+    size_t pos = val.find(homeToken);
+    if (pos != std::string::npos)
+      val.replace(pos, homeToken.size(), homeDir);
+    return val;
+  }
+  return "";
+}
