#!/bin/sh
# postinst script for test
#
# see: dh_installdeb(1)

set -e

# summary of how this script can be called:
#        * <postinst> `configure' <most-recently-configured-version>
#        * <old-postinst> `abort-upgrade' <new version>
#        * <conflictor's-postinst> `abort-remove' `in-favour' <package>
#          <new-version>
#        * <postinst> `abort-remove'
#        * <deconfigured's-postinst> `abort-deconfigure' `in-favour'
#          <failed-install-package> <version> `removing'
#          <conflicting-package> <version>
# for details, see https://www.debian.org/doc/debian-policy/ or
# the debian-policy package

SERVER_USER=${SERVER_USER:-aaruremote}
SERVER_GROUP=${SERVER_GROUP:-aaruremote}
SERVER_HOME=/var/lib/aaruremote

case "$1" in
    configure)
		# 1. create group if not existing
		if ! getent group | grep -q "^$SERVER_GROUP:" ; then
	    	echo -n "Adding system group $SERVER_GROUP.."
	    	addgroup --quiet --system $SERVER_GROUP 2>/dev/null ||true
	 		echo "..done"
  		fi
		# 2. create user if not existing
		if ! getent passwd | grep -q "^$SERVER_USER:"; then
    		echo -n "Adding system user $SERVER_USER.."
		    adduser --quiet \
		            --system \
		            --ingroup $SERVER_GROUP \
		            --home "$SERVER_HOME" \
		            --no-create-home \
		            --disabled-password \
		            $SERVER_USER 2>/dev/null || true
		    usermod -aG disk,cdrom aaruremote
		    echo "..done"
		# 3. create log files & adjust their directory permissions
		test -f /var/log/aaruremote.log || touch /var/log/aaruremote.log
		chown $SERVER_USER:aaruremote /var/log/aaruremote.log
		# 4. Create home directory
        mkdir -p "$SERVER_HOME"
        chown "$SERVER_USER:$SERVER_GROUP" "$SERVER_HOME"
        chmod 750 "$SERVER_HOME"
		fi
    ;;

    abort-upgrade|abort-remove|abort-deconfigure)
    ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

#DEBHELPER#

exit 0
