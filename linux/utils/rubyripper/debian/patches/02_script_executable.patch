Description: make ruby scripts executable
Author: Nicolas HOUDELOT <nicolas@demosdebs.org>
Applied-Upstream: no
Last-Update: 2024-03-13
---
This patch header follows DEP-3: http://dep.debian.net/deps/dep3/
--- a/configure
+++ b/configure
@@ -165,7 +165,7 @@
 makefile.puts ""
 makefile.puts "install:"
 Dir.glob("#{$RUBYDIR[1..-1]}/**/*.rb").each do |file|
-  makefile.puts "\t#{$INSTALL} -m 644 #{file} $(prefix)$(DESTDIR)#{$PREFIX}/#{file}"
+  makefile.puts "\t#{$INSTALL} -m 755 #{file} $(prefix)$(DESTDIR)#{$PREFIX}/#{file}"
 end
 
 if $GTK3
