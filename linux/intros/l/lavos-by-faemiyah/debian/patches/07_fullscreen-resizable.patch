+      if(out_aspect >= fbo_aspect)
+      {
+        // Barres gauche/droite (pillarbox).
+        blit_h = g_output_h;
+        blit_w = static_cast<GLsizei>(static_cast<float>(g_output_h) * fbo_aspect + 0.5f);
+        blit_x = (g_output_w - blit_w) / 2;
+        blit_y = 0;
+      }
+      else
+      {
+        // Barres haut/bas (letterbox).
+        blit_w = g_output_w;
+        blit_h = static_cast<GLsizei>(static_cast<float>(g_output_w) / fbo_aspect + 0.5f);
+        blit_x = 0;
+        blit_y = (g_output_h - blit_h) / 2;
+      }
+    }
+
+    // Echelle FBO -> zone blit (remplace l'ancienne division par g_screen_w/h).
+    g_uniform_array[1] /= static_cast<float>(blit_w);
