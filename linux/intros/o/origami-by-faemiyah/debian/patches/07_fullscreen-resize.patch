+void screen_resize(int w, int h)
+{
+	int vp_w, vp_h;
+
+	win_w = w;
+	win_h = h;
+
+	if(w * 3 >= h * 4)
+	{
+		/* Window is wider than 4:3 → pillarbox (vertical black bars). */
+		vp_h = h;
+		vp_w = h * 4 / 3;
+	}
+	else
+	{
+		/* Window is taller than 4:3 → letterbox (horizontal black bars). */
+		vp_w = w;
+		vp_h = w * 3 / 4;
+	}
+
+	vp_x = (w - vp_w) / 2;
+	vp_y = (h - vp_h) / 2;
+
+	screen_w = vp_w;
+	screen_h = vp_h;
+
+	glViewport(vp_x, vp_y, vp_w, vp_h);
+	glScissor(vp_x, vp_y, vp_w, vp_h);
+	glEnable(GL_SCISSOR_TEST);
+}
