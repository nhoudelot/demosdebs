-/// Array new.
+/// Allocate a raw untyped buffer of the given byte size.
 ///
-/// Replacement for new[] using realloc().
-/// Use with types that have destructors is not supported.
+/// Thin wrapper around dnload_realloc(NULL, sz).  Used for the initial
+/// allocation in seq<T> (where no objects exist yet) and for the
+/// non-trivially-copyable resize path in seq::resizeInternal().
+/// Using this helper instead of array_new() avoids the
+/// -Wclass-memaccess warning that GCC emits when realloc() is called
+/// with a typed pointer to a non-trivially copyable type.
+///
+/// \param sz Byte size to allocate.
+/// \return Allocated pointer.
+inline void* array_alloc_raw(size_t sz)
+{
+#if defined(USE_LD)
+  if(!sz)
+  {
+    BOOST_THROW_EXCEPTION(std::runtime_error("array_alloc_raw: size 0"));
+  }
+#endif
+  void* ptr = dnload_realloc(NULL, sz);
+#if defined(USE_LD)
+  if(!ptr)
+  {
+    std::ostringstream sstr;
+    sstr << "array_alloc_raw: allocating " << sz << " bytes failed";
+    BOOST_THROW_EXCEPTION(std::runtime_error(sstr.str()));
+  }
+  g_total += sz;
+#endif
+  return ptr;
+}
