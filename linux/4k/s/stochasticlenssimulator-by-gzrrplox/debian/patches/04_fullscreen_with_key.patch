@@ -32,6 +32,8 @@
 GLuint fbo_sound, sound_tex, pbo_sound;
 GLuint vertices;
 
+SDL_Window *sdlWindow;
+
 // Sound texture store
 float sound_data[2200*10*3];
 
@@ -51,11 +53,12 @@
 #version 150\n\
 #extension GL_ARB_texture_rectangle : enable\n\
 uniform sampler2DRect tex;\
+uniform vec2 scale;\
 out vec4 color;\
 \
 void main(){\
     vec2 coord = gl_FragCoord.st;\
-    color = texture2DRect(tex, coord * " SCALE ");\
+    color = texture2DRect(tex, coord * scale);\
 }";
 
 // I don't like single pixel wide box filters too much, so reduce image
@@ -475,11 +478,30 @@
 	draw_part(fbo_y, image_w, image_h, fbo_xtex, filter_prog);
 
 	// Draw downsampled image on screen
-	draw_part(0, window_w, window_h, fbo_ytex, display_prog);
+	int cur_w, cur_h;
+	SDL_GL_GetDrawableSize(sdlWindow, &cur_w, &cur_h);
+	glBindFramebuffer(GL_FRAMEBUFFER, 0);
+	glViewport(0, 0, cur_w, cur_h);
+	glBindTexture(GL_TEXTURE_RECTANGLE, fbo_ytex);
+	glUseProgram(display_prog);
+
+	// Recalcul du SCALE dynamique : ramener les coordonnées écran vers les coordonnées image
+	GLuint scale_loc = glGetUniformLocation(display_prog, "scale");
+	glUniform2f(scale_loc, float(image_w) / float(cur_w), float(image_h) / float(cur_h));
+
+	glRecti(-1, -1, 1, 1);
 #endif
 }
 
 
+static void ToggleFullscreen(SDL_Window* Window) {
+    int FullscreenFlag = SDL_WINDOW_FULLSCREEN_DESKTOP;
+    int isFullscreen = SDL_GetWindowFlags(Window) & FullscreenFlag;
+    SDL_SetWindowFullscreen(Window, isFullscreen ? 0 : FullscreenFlag);
+    SDL_ShowCursor(isFullscreen);
+}
+
