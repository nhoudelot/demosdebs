--- a/src/main.cpp
+++ b/src/main.cpp
@@ -61,6 +61,8 @@
 Sint16 samples[sample_batch * sample_buffers];
 
 
+SDL_Window *sdlWindow;
+
 ////////////////////////////////////////////////////////////////////////////////
 // Uninteresting OpenGL utilities
 ////////////////////////////////////////////////////////////////////////////////
@@ -228,10 +230,53 @@
 	draw_part(fbo_y, image_w, image_h, fbo_xtex, filter_prog);
 
 	// Draw downsampled image on screen
-	draw_part(0, window_w, window_h, fbo_ytex, display_prog);
+	int cur_w, cur_h;
+	SDL_GL_GetDrawableSize(sdlWindow, &cur_w, &cur_h);
+
+	// Calcul du ratio
+	float src_ratio = float(image_w) / float(image_h);
+	float dst_ratio = float(cur_w)   / float(cur_h);
+
+	int dst_w, dst_h, dst_x, dst_y;
+
+	if (dst_ratio > src_ratio) {
+		// Écran plus large que l'image → bandes noires à gauche/droite
+		dst_h = cur_h;
+		dst_w = int(cur_h * src_ratio);
+		dst_x = (cur_w - dst_w) / 2;
+		dst_y = 0;
+	} else {
+		// Écran plus haut que l'image → bandes noires en haut/bas
+		dst_w = cur_w;
+		dst_h = int(cur_w / src_ratio);
+		dst_x = 0;
+		dst_y = (cur_h - dst_h) / 2;
+	}
+
+	// Effacer l'écran (bandes noires)
+	glBindFramebuffer(GL_FRAMEBUFFER, 0);
+	glViewport(0, 0, cur_w, cur_h);
+	glClearColor(0, 0, 0, 1);
+	glClear(GL_COLOR_BUFFER_BIT);
+
+	// Blit avec zoom et ratio correct
+	glBindFramebuffer(GL_READ_FRAMEBUFFER, fbo_y);
+	glBindFramebuffer(GL_DRAW_FRAMEBUFFER, 0);
+	glBlitFramebuffer(
+		0,       0,       image_w, image_h,
+		dst_x,   dst_y,   dst_x + dst_w, dst_y + dst_h,
+		GL_COLOR_BUFFER_BIT,
+		GL_LINEAR
+	);
 #endif
 }
 
+void ToggleFullscreen(SDL_Window* Window) {
+    int FullscreenFlag = SDL_WINDOW_FULLSCREEN_DESKTOP;
+    int isFullscreen = SDL_GetWindowFlags(Window) & FullscreenFlag;
+    SDL_SetWindowFullscreen(Window, isFullscreen ? 0 : FullscreenFlag);
+    SDL_ShowCursor(isFullscreen);
+}
 
