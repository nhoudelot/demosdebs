+# ---------------------------------------------------------------------------
+# output_flags_remove_cxx_std()
+#   CORRECTIF : remplace output_flags_remove_cxx11() dont la logique
+#   string(REPLACE) était fragile (espaces, ordre).
+#   Supprime tout flag -std=c++NN des CMAKE_CXX_FLAGS globaux.
+#   Utile pour les projets qui imposent leur propre standard via
+#   set_target_properties(... CXX_STANDARD ...).
+# ---------------------------------------------------------------------------
+function(output_flags_remove_cxx_std)
+  string(REGEX REPLACE " ?-std=c\\+\\+[0-9a-z]+" "" _cleaned "${CMAKE_CXX_FLAGS}")
+  string(STRIP "${_cleaned}" _cleaned)
+  set(CMAKE_CXX_FLAGS "${_cleaned}" PARENT_SCOPE)
+endfunction()
