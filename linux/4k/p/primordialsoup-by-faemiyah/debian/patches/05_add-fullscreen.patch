@@ -787,6 +792,27 @@
 #endif
 }
 
+#if defined(USE_LD) && !defined(SDL12)
+
+static void SetViewport(SDL_Window *window)
+{
+  int dw = 0;
+  int dh = 0;
+  SDL_GL_GetDrawableSize(window, &dw, &dh);
+  glViewport(0, 0, dw, dh);
+}
+
+static void ToggleFullscreen(SDL_Window *window)
+{
+  g_fullscreen = !g_fullscreen;
+  SDL_SetWindowFullscreen(window,
+      g_fullscreen ? SDL_WINDOW_FULLSCREEN_DESKTOP : 0);
+  SDL_PumpEvents();
+  SetViewport(window);
+}
+
+#endif // USE_LD && !SDL12
+
