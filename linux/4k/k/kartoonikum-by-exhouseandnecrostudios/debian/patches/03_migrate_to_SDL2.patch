--- a/Makefile
+++ b/Makefile
@@ -48,11 +48,11 @@
 ifeq ($(PLATFORM), LINUX)
 	CFLAGS += -DSDL
 	ifeq ($(DEBUG),TRUE)
-		CFLAGS += -ggdb -DDEBUG -fno-strict-aliasing -std=c99 $(shell $(PKG_CONFIG) --cflags sdl) $(INCLUDES)
