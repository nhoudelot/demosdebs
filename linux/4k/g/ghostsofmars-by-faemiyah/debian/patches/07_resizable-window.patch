Description: make window resizable
 make window resizable with correct aspect ratio
Author: Nicolas HOUDELOT <nicolas@demosdebs.org> & Claude Sonnet 4.6
Applied-Upstream: no
Last-Update: 2026-04-01
---
This patch header follows DEP-3: http://dep.debian.net/deps/dep3/
--- a/src/intro.cpp
+++ b/src/intro.cpp
@@ -571,8 +571,8 @@
 #endif
   dnload();
   dnload_SDL_Init(SDL_INIT_VIDEO | SDL_INIT_AUDIO);
-  SDL_Window *window = dnload_SDL_CreateWindow(NULL, 0, 0, static_cast<int>(screen_w),
-      static_cast<int>(screen_h), SDL_WINDOW_OPENGL | (flag_fullscreen ? SDL_WINDOW_FULLSCREEN_DESKTOP : 0));
+  SDL_Window *window = dnload_SDL_CreateWindow("Ghosts of Mars by Faemiyah", 0, 0, static_cast<int>(screen_w),
+      static_cast<int>(screen_h), SDL_WINDOW_OPENGL | SDL_WINDOW_RESIZABLE | (flag_fullscreen ? SDL_WINDOW_FULLSCREEN_DESKTOP : 0));
   dnload_SDL_GL_CreateContext(window);
   dnload_SDL_ShowCursor(flag_developer);
 #if defined(USE_LD)
@@ -833,6 +833,30 @@
       {
         quit = true;
       }
+      else if(SDL_WINDOWEVENT == event.type)
+		{
+		  if(SDL_WINDOWEVENT_RESIZED == event.window.event ||
+			 SDL_WINDOWEVENT_SIZE_CHANGED == event.window.event)
+		  {
+			int new_w = event.window.data1;
+			int new_h = event.window.data2;
+
+			glViewport(0, 0, new_w, new_h);
+
+			float fw = static_cast<float>(new_w);
+			float fh = static_cast<float>(new_h);
+			if(new_w > new_h)
+			{
+			  glProgramUniform3f(g_program_fragment, g_uniform_aspect,
+				  fw / fh, 1.0f, 2.0f / fh);
+			}
+			else
+			{
+			  glProgramUniform3f(g_program_fragment, g_uniform_aspect,
+				  1.0f, fh / fw, 2.0f / fw);
+			}
+		  }
+		}
       else if(SDL_KEYDOWN == event.type)
       {
         switch(event.key.keysym.sym)
