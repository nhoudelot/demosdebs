+
+    //glViewport(vpX, vpY, vpW, vpH);
+    SetViewport(sdlWindow);
+    introInit();
 
 #ifndef CAPTURE
 #ifndef NO_AUDIO
@@ -478,6 +526,11 @@
 		SDL_Event e;
 		SDL_PollEvent(&e);
 		if ((e.type == SDL_KEYDOWN && e.key.keysym.sym == SDLK_ESCAPE) || now >= INTRO_LENGTH) break;
+		if (e.type == SDL_KEYUP) {
+		    switch (e.key.keysym.sym) {
