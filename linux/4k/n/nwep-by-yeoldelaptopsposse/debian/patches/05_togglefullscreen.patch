Description: added fullscreen key
 added fullscreen function, to go fullscreen and back, with F key
Author: Nicolas HOUDELOT <nicolas@demosdebs.org>
Applied-Upstream: no
Last-Update: 2024-03-29
---
This patch header follows DEP-3: http://dep.debian.net/deps/dep3/
--- a/nwep.c
+++ b/nwep.c
@@ -278,12 +278,13 @@
 	oglFramebufferTexture2D(GL_FRAMEBUFFER, GL_COLOR_ATTACHMENT0, GL_TEXTURE_2D, tex, 0);
 }
 
-static void paint(int prog, int src_tex, int dst_fb, float time) {
+static void paint(int prog, int src_tex, int dst_fb, float time,
+                  float outW, float outH) {
 	oglUseProgram(prog);
 	glBindTexture(GL_TEXTURE_2D, src_tex);
 	oglBindFramebuffer(GL_FRAMEBUFFER, dst_fb);
 	oglUniform1i(oglGetUniformLocation(prog, "B"), 0);
-	oglUniform3f(oglGetUniformLocation(prog, "V"), (float)XRES, (float)YRES, time);
+	oglUniform3f(oglGetUniformLocation(prog, "V"), outW, outH, time);
 	oglUniform3f(oglGetUniformLocation(prog, "C"), TV[0], TV[1], TV[2]);
 	oglUniform3f(oglGetUniformLocation(prog, "A"), TV[3], TV[4], TV[5]);
 	oglUniform3f(oglGetUniformLocation(prog, "D"), TV[6], TV[7], TV[8]);
@@ -318,10 +319,16 @@
 	//initFbTex(tex[FbTex_Dof], fb[FbTex_Dof]);
 }
 
+static int vpX, vpY, vpW, vpH;
+
 static __forceinline void introPaint(float time) {
 	timelineUpdate(time);
-	paint(p_ray, 0, fb[FbTex_Ray], time);
-	paint(p_dof, tex[FbTex_Ray], 0, time);
+	/* passe raymarch : rendu dans le framebuffer interne XRES x YRES */
+    glViewport(0, 0, XRES, YRES);
+    paint(p_ray, 0, fb[FbTex_Ray], time, (float)XRES, (float)YRES);
+    /* passe post : blit vers l'écran dans le viewport zoomé */
+    glViewport(vpX, vpY, vpW, vpH);
+    paint(p_dof, tex[FbTex_Ray], 0, time, (float)vpW, (float)vpH);
 }
 
 #ifdef _WIN32
@@ -435,6 +442,29 @@
 };
 #endif /* AUDIO */
 
+static void SetViewport(SDL_Window *window) {
+    int drawW, drawH;
+    SDL_GL_GetDrawableSize(window, &drawW, &drawH);
+
+    if (drawW * YRES > drawH * XRES) {
+        vpH = drawH;
+        vpW = drawH * XRES / YRES;
+    } else {
+        vpW = drawW;
+        vpH = drawW * YRES / XRES;
+    }
+    vpX = (drawW - vpW) / 2;
+    vpY = (drawH - vpH) / 2;
+}
+
+void ToggleFullscreen(SDL_Window *window) {
+    Uint32 flag = SDL_WINDOW_FULLSCREEN_DESKTOP;
+    int isFS = SDL_GetWindowFlags(window) & flag;
+    SDL_SetWindowFullscreen(window, isFS ? 0 : flag);
+    SDL_ShowCursor(isFS);
+    SetViewport(window);
+}
+
 #ifndef COMPACT
 int main() {
 #else
