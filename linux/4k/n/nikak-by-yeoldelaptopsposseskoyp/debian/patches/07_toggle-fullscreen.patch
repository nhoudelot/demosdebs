+static void blitLetterbox(int src_w, int src_h, int dst_w, int dst_h) {
+    const float src_ratio = (float)src_w / src_h;
+    const float dst_ratio = (float)dst_w / dst_h;
+    int x = 0, y = 0, w = dst_w, h = dst_h;
+
+    if (dst_ratio > src_ratio) {
+        /* écran plus large : bandes à gauche/droite */
+        w = (int)(dst_h * src_ratio);
+        x = (dst_w - w) / 2;
+    } else {
+        /* écran plus haut : bandes en haut/bas */
+        h = (int)(dst_w / src_ratio);
+        y = (dst_h - h) / 2;
+    }
+
+    glClear(GL_COLOR_BUFFER_BIT);   /* bandes noires */
+    glBlitFramebuffer(
+        0, 0, src_w, src_h,
+        x, y, x + w, y + h,
+        GL_COLOR_BUFFER_BIT, GL_LINEAR);
+}
