+
+void ToggleFullscreen(SDL_Window* window) {
+    const Uint32 flag = SDL_WINDOW_FULLSCREEN_DESKTOP;
+    const int is_fullscreen = SDL_GetWindowFlags(window) & flag;
+    int isFS = SDL_GetWindowFlags(window) & flag;
+    SDL_SetWindowFullscreen(window, isFS ? 0 : flag);
+    SDL_ShowCursor(isFS);
+    SetViewport(window);
+}
