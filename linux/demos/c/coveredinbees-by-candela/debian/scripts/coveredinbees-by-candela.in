#!/bin/bash -e

source /usr/share/common-install-function-ddebs/common-install-function

domain=coveredinbees-by-candela

APP_FULLNAME="Covered in Bees"
APP_COPYRIGHT="Candela"
APP_DESC="demo by Candela released in 2012"

APP_EXE="@EXE@ -w 1280 -h 720 -win"

function run()
{
	backuppwd=$(pwd)
	cd /usr/lib/@DEB_HOST_MULTIARCH@/${domain}
	LD_LIBRARY_PATH=./:/usr/lib/@DEB_HOST_MULTIARCH@/sdl12-compat/ ./${APP_EXE}
	cd $backuppwd
}


if [ "$#" -gt "1" ]; then
	 NSH_std_usage
	exit 1
elif [ "$#" -lt "1" ]; then
	run
else
	case "$1" in
	--help)
		NSH_std_usage
		;;
	*)
		NSH_std_usage
		exit 1
		;;
	esac
fi

exit 0
