Description: migrate to SDL2
 Migrate from SDL1.2 to SDL2
 main.c:
  - Remove unused #include <unistd.h>
  - Enable VSync via SDL_GL_SetSwapInterval(1) to avoid busy-looping
    the GPU between frames
  - Call resize_window() at startup so the initial glViewport matches
    the 4:3 aspect-ratio logic from the start
  - Use AUDIO_S16SYS instead of AUDIO_S16 for big-endian portability
 texture.c:
  - Remove unused includes: <SDL2/SDL.h>, <unistd.h>, <math.h>
 .
 wayang.h:
  - Add #include <SDL2/SDL.h> so that Uint32 (used in show_wayang)
    is always defined regardless of include order
  - Remove duplicate 'extern Mesh3D *arrow' declaration
Author: Nicolas HOUDELOT <nicolas@demosdebs.org>
Applied-Upstream: no
Last-Update: 2020-05-01
---
This patch header follows DEP-3: http://dep.debian.net/deps/dep3/
--- a/Makefile
+++ b/Makefile
@@ -2,8 +2,8 @@
 SHELL := /bin/sh
 CC    := gcc
 PKG_CONFIG:=pkg-config
-CFLAGS += -Wall -pedantic $(shell $(PKG_CONFIG) gl sdl libpng SDL_mixer --cflags) -std=gnu90 -pipe
-LDFLAGS +=  -L/usr/X11R6/lib $(shell $(PKG_CONFIG) gl sdl libpng SDL_mixer --libs) -lm
+CFLAGS += -Wall -pedantic $(shell $(PKG_CONFIG) gl sdl2 libpng SDL2_mixer --cflags) -std=gnu90 -pipe
+LDFLAGS +=  -L/usr/X11R6/lib $(shell $(PKG_CONFIG) gl sdl2 libpng SDL2_mixer --libs) -lm
 TARGET   := wayang-by-cyberneticgenetics
 #variable de nettoyage
 RM_F := rm -f
