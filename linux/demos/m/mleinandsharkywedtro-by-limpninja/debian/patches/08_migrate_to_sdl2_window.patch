+// Ratio natif défini par glOrtho: 26.6 / 20 = 4/3
+static const float NATIVE_ASPECT = 4.0f / 3.0f;
 
+static void computeViewport( int w, int h )
+{
+	float windowAspect = (float)w / (float)h;
+	if (windowAspect > NATIVE_ASPECT)
+	{
+		// fenêtre trop large : bandes noires à gauche/droite
+		g_vpH = h;
+		g_vpW = (int)(h * NATIVE_ASPECT);
+		g_vpX = (w - g_vpW) / 2;
+		g_vpY = 0;
+	}
+	else
+	{
+		// fenêtre trop haute : bandes noires en haut/bas
+		g_vpW = w;
+		g_vpH = (int)(w / NATIVE_ASPECT);
+		g_vpX = 0;
+		g_vpY = (h - g_vpH) / 2;
+	}
+}
 
 void reshape( int w, int h )
