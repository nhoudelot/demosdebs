Description: fix 64-bit portability in Heightfield::noise()
 The noise hash function used signed integer arithmetic for bit operations,
 causing undefined behaviour (signed overflow and left-shift of a negative
 value). Switch to unsigned int so all bit manipulations are well-defined
 on both 32-bit and 64-bit targets.
Author: Nicolas HOUDELOT <nicolas@demosdebs.org>
Applied-Upstream: no
Last-Update: 2026-04-25
---
This patch header follows DEP-3: http://dep.debian.net/deps/dep3/
--- a/src/Heightfield.cpp
+++ b/src/Heightfield.cpp
@@ -306,9 +306,9 @@ float Heightfield::noise(float x, float y)
 {

-	int n = (int)(x + y * 57);
+	unsigned int n = (unsigned int)(int)(x + y * 57);
 	n = (n << 13) ^ n;

-	return (float)(1.0 - ((n * (n * n * 15731 + 789221) +
-	                       1376312589) & 0x7FFFFFFF) / 1073741824.0);
+	return (float)(1.0 - (int)((n * (n * n * 15731u + 789221u) +
+	                       1376312589u) & 0x7FFFFFFFu) / 1073741824.0);
 }
