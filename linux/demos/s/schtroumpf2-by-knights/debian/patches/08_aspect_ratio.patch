+static void UpdateViewport(int win_w, int win_h)
+{
+	WindowW = win_w;
+	WindowH = win_h;
+	if ((long)win_w * 768 > (long)win_h * 1024) {
+		ViewportH = win_h;
+		ViewportW = win_h * 1024 / 768;
+	} else {
+		ViewportW = win_w;
+		ViewportH = win_w * 768 / 1024;
+	}
+	ViewportX = (win_w - ViewportW) / 2;
+	ViewportY = (win_h - ViewportH) / 2;
+}
+
+void RestoreViewport(void)
+{
+	glViewport(ViewportX, ViewportY, ViewportW, ViewportH);
+}
