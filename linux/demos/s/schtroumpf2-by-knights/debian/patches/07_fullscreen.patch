Description: Fullscreen toggle via F key
 Adds fullscreen toggle with the F key using SDL_WINDOW_FULLSCREEN_DESKTOP
 (desktop resolution, no mode change). Also adds SDL_WINDOW_RESIZABLE so
 the window can be properly restored when leaving fullscreen.
Generated-by: Claude Sonnet 4.6
Reviewed-by: Nicolas HOUDELOT <nicolas@demosdebs.org>
Applied-Upstream: no
---
This patch header follows DEP-3: http://dep.debian.net/deps/dep3/
--- a/src/introsystem.c
+++ b/src/introsystem.c
@@ -74,6 +74,8 @@
 	printf("%d surfaces used: %dKb\n",stat_surfaces, stat_surface_mem);
 }
 
+extern SDL_Window *sdlWindow;
+
 int CheckUserBreak()
 {
 #ifdef USE_SDL	
@@ -86,6 +88,11 @@
 			if (event.key.keysym.sym == SDLK_ESCAPE) {
 				return 1;
 			}
+			if (event.key.keysym.sym == SDLK_f) {
+				Fullscreen = !Fullscreen;
+				SDL_SetWindowFullscreen(sdlWindow,
+					Fullscreen ? SDL_WINDOW_FULLSCREEN_DESKTOP : 0);
+			}
 		}
 	}
 #else
