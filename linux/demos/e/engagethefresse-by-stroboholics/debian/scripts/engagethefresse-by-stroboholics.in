#!/bin/bash -e

source /usr/share/common-install-function-ddebs/common-install-function

domain=engagethefresse-by-stroboholics

APP_FULLNAME="ENGAGE THE FRESSE"
APP_COPYRIGHT="stroboholics"
APP_DESC="demo by stroboholics released in 2010"

APP_EXE="@EXE@"

function run()
{
	backuppwd=$(pwd)
	cd /usr/lib/@DEB_HOST_MULTIARCH@/${domain}
	SDL12COMPAT_OPENGL_SCALING=0 LD_LIBRARY_PATH=./:/usr/lib/@DEB_HOST_MULTIARCH@/sdl12-compat/ ./${APP_EXE}
	cd $backuppwd
}


if [ "$#" -gt "1" ]; then
	 NSH_std_usage
	exit 1
elif [ "$#" -lt "1" ]; then
	run
else
	case "$1" in
	--help)
		NSH_std_usage
		;;
	*)
		NSH_std_usage
		exit 1
		;;
	esac
fi

exit 0
