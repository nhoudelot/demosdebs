+++ b/Sources/linux_sdl2.cpp
@@ -0,0 +1,109 @@
+/*
+ * SDL2 audio driver: uses SDL_QueueAudio (push model).
+ * Mirrors the interface of the OSS and ALSA drivers.
+ */
+#include "linux_sdl2.h"
+
+#include <stdio.h>
+#include <string.h>
+#include <sys/time.h>
+
+#define SAMPLE_RATE      44100
+#define NUM_CHANNELS     2
+#define BYTES_PER_FRAME  4        /* sizeof(short) * NUM_CHANNELS */
+#define PERIOD_FRAMES    4096
+
+SDL2AudioDriver::SDL2AudioDriver(MP3AudioProvider *prv)
+{
+	this->prov = prv;
+	this->in_outbuf = 0;
+	this->bytes_written = 0;
+	this->eof = false;
+	this->last_audio_base = -1.0f;  /* sentinel : premier appel non encore initialisĂ© */
+	this->last_wall_time.tv_sec = 0;
+	this->last_wall_time.tv_usec = 0;
+
+	SDL_AudioSpec want, got;
+	SDL_zero(want);
+	want.freq     = SAMPLE_RATE;
+	want.format   = AUDIO_S16LSB;
+	want.channels = NUM_CHANNELS;
+	want.samples  = PERIOD_FRAMES;
+	want.callback = NULL;         /* push mode: we call SDL_QueueAudio */
+
+	this->dev_id = SDL_OpenAudioDevice(NULL, 0, &want, &got, 0);
+	if (this->dev_id == 0) {
+		fprintf(stderr, "SDL_OpenAudioDevice failed: %s\n", SDL_GetError());
+		exit(-1);
+	}
+	SDL_PauseAudioDevice(this->dev_id, 0);
+}
+
+SDL2AudioDriver::~SDL2AudioDriver()
+{
+	SDL_CloseAudioDevice(this->dev_id);
+}
+
+bool SDL2AudioDriver::run()
+{
+	if (this->eof) {
+		struct timeval now;
+		gettimeofday(&now, NULL);
+		float secs = (float)(now.tv_sec  - eof_time.tv_sec) +
+		             (float)(now.tv_usec - eof_time.tv_usec) * 0.000001f;
+		this->bytes_written += (int)(secs * SAMPLE_RATE * BYTES_PER_FRAME);
+		memcpy(&this->eof_time, &now, sizeof(struct timeval));
+		return true;
+	}
+
+	/* Keep ~1 second of audio pre-buffered in the SDL queue. */
+	while (SDL_GetQueuedAudioSize(this->dev_id) <
+	       (Uint32)(SAMPLE_RATE * BYTES_PER_FRAME)) {
+		int ret = this->prov->fill_buf(this->outbuf + this->in_outbuf,
+		                               65536 - this->in_outbuf);
+		if (ret == 0) {
+			this->eof = true;
+			gettimeofday(&this->eof_time, NULL);
+			return true;
+		}
+		this->in_outbuf += ret;
+
+		while (this->in_outbuf >= PERIOD_FRAMES * BYTES_PER_FRAME) {
+			int chunk = PERIOD_FRAMES * BYTES_PER_FRAME;
+			if (SDL_QueueAudio(this->dev_id, this->outbuf, chunk) != 0)
+				fprintf(stderr, "SDL_QueueAudio: %s\n", SDL_GetError());
+			this->bytes_written += chunk;
+			this->in_outbuf -= chunk;
+			memmove(this->outbuf, this->outbuf + chunk, this->in_outbuf);
+		}
+	}
+	return false;
+}
+
+float SDL2AudioDriver::get_time()
+{
+	Uint32 queued = SDL_GetQueuedAudioSize(this->dev_id);
+	int played = this->bytes_written - (int)queued;
+	if (played < 0)
+		played = 0;
+	float audio_base = (float)played / SAMPLE_RATE / BYTES_PER_FRAME;
+
+	struct timeval now;
+	gettimeofday(&now, NULL);
+
+	if (this->last_audio_base < 0.0f || audio_base > this->last_audio_base) {
+		/* Premier appel ou nouvelle mesure audio : recaler la rĂ©fĂ©rence. */
+		this->last_audio_base = audio_base;
+		this->last_wall_time  = now;
+		return audio_base;
+	}
+
+	/* Entre deux quanta audio, extrapoler avec l'horloge systĂ¨me.
+	   On plafonne Ă  100 ms pour Ă©viter toute dĂ©rive en cas de blocage. */
+	float wall_elapsed = (float)(now.tv_sec  - this->last_wall_time.tv_sec)
+	                   + (float)(now.tv_usec - this->last_wall_time.tv_usec) * 0.000001f;
+	if (wall_elapsed > 0.1f)
+		wall_elapsed = 0.1f;
+
+	return this->last_audio_base + wall_elapsed;
+}
