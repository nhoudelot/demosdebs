 	sourcefile = fopen(fn,"rt");
 
@@ -48,9 +49,9 @@
 		rewind(sourcefile);
 
 		if (count > 0) {
-			content = (char *)malloc(sizeof(char) * (count+1));
-			count = fread(content, sizeof(char), count, sourcefile);
-			content[count] = '\0';
