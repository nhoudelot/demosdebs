+#include <SDL2/SDL.h>
+#include <SDL2/SDL_opengl.h>
+
+#define BEGIN_EVENT \
+while(cg_isrunning){\
+   SDL_Event cg_event;\
+   while(SDL_PollEvent(&cg_event)){\
+      if(cg_event.type == SDL_QUIT) cg_isrunning = 0;\
+      if(cg_event.type == SDL_WINDOWEVENT &&\
+         cg_event.window.event == SDL_WINDOWEVENT_RESIZED) cg_UpdateViewport();\
+      if(cg_event.type == SDL_KEYDOWN){\
+         if(cg_event.key.keysym.sym == SDLK_ESCAPE) cg_isrunning = 0;\
+         if(cg_event.key.keysym.sym == SDLK_f) ToggleFullscreen();\
+      }\
+   }
+
+#define END_EVENT SDL_GL_SwapWindow(cg_window);}
+
+extern SDL_Window    *cg_window;
+extern SDL_GLContext  cg_context;
+extern char           cg_isrunning;
+extern int            cg_render_w, cg_render_h;
+
