+
+char          cg_isrunning = 1;
+SDL_Window   *cg_window   = NULL;
+SDL_GLContext cg_context   = NULL;
+int           cg_screen_mode;
+int           cg_render_w, cg_render_h;
+
+static int cg_win_w, cg_win_h;
+
+/* Letterbox viewport : conserve le ratio de rendu dans la fenetre */
+void cg_UpdateViewport(void){
+	int win_w, win_h;
+	int vp_x, vp_y, vp_w, vp_h;
+	float render_aspect, win_aspect;
+
+	SDL_GL_GetDrawableSize(cg_window, &win_w, &win_h);
+	render_aspect = (float)cg_render_w / (float)cg_render_h;
+	win_aspect    = (float)win_w        / (float)win_h;
+
+	if(win_aspect > render_aspect) {
+		vp_h = win_h;
+		vp_w = (int)(win_h * render_aspect);
+		vp_x = (win_w - vp_w) / 2;
+		vp_y = 0;
+	} else {
+		vp_w = win_w;
+		vp_h = (int)(win_w / render_aspect);
+		vp_x = 0;
+		vp_y = (win_h - vp_h) / 2;
+	}
+	glViewport(vp_x, vp_y, vp_w, vp_h);
+}
+
+void ToggleFullscreen(void){
+	if(cg_screen_mode == CG_FULLSCREEN) {
+		SDL_SetWindowFullscreen(cg_window, 0);
+		SDL_SetWindowSize(cg_window, cg_win_w, cg_win_h);
+		SDL_ShowCursor(SDL_ENABLE);
+		cg_screen_mode = CG_WINDOW;
+	} else {
+		SDL_SetWindowFullscreen(cg_window, SDL_WINDOW_FULLSCREEN_DESKTOP);
+		SDL_ShowCursor(SDL_DISABLE);
+		cg_screen_mode = CG_FULLSCREEN;
+	}
+	cg_UpdateViewport();
+}
+
+int CreateScene(int width, int height, int mode){
+	Uint32 flags;
+
+	if(SDL_Init(SDL_INIT_VIDEO) < 0) {
+		fprintf(stderr, "SDL_Init error: %s\n", SDL_GetError());
+		return(-1);
+	}
+
+	SDL_GL_SetAttribute(SDL_GL_CONTEXT_MAJOR_VERSION, 4);
+	SDL_GL_SetAttribute(SDL_GL_CONTEXT_MINOR_VERSION, 1);
+	SDL_GL_SetAttribute(SDL_GL_CONTEXT_PROFILE_MASK,  SDL_GL_CONTEXT_PROFILE_CORE);
+	SDL_GL_SetAttribute(SDL_GL_DOUBLEBUFFER, 1);
+	SDL_GL_SetAttribute(SDL_GL_DEPTH_SIZE,   12);
+	SDL_GL_SetAttribute(SDL_GL_RED_SIZE,      4);
+	SDL_GL_SetAttribute(SDL_GL_GREEN_SIZE,    4);
+	SDL_GL_SetAttribute(SDL_GL_BLUE_SIZE,     4);
+	SDL_GL_SetAttribute(SDL_GL_ALPHA_SIZE,    4);
+
+	cg_render_w  = width;
+	cg_render_h  = height;
+	cg_win_w     = width;
+	cg_win_h     = height;
+	cg_screen_mode = mode;
+
+	flags = SDL_WINDOW_OPENGL | SDL_WINDOW_RESIZABLE | SDL_WINDOW_SHOWN;
+
+	cg_window = SDL_CreateWindow("Livin in a Box - Cybernetic Genetics",
+	                              SDL_WINDOWPOS_CENTERED,
+	                              SDL_WINDOWPOS_CENTERED,
+	                              width, height, flags);
+	if(!cg_window) {
+		fprintf(stderr, "SDL_CreateWindow error: %s\n", SDL_GetError());
+		return(-1);
+	}
+
+	cg_context = SDL_GL_CreateContext(cg_window);
+	if(!cg_context) {
+		fprintf(stderr, "SDL_GL_CreateContext error: %s\n", SDL_GetError());
+		return(-1);
+	}
+
+	SDL_GL_SetSwapInterval(1);
+
+	if(mode == CG_FULLSCREEN) {
+		SDL_SetWindowFullscreen(cg_window, SDL_WINDOW_FULLSCREEN_DESKTOP);
+		SDL_ShowCursor(SDL_DISABLE);
+	}
+
+	cg_UpdateViewport();
+	return(0);
+}
+
+void RestoreScene(void){
+	SDL_GL_DeleteContext(cg_context);
+	SDL_DestroyWindow(cg_window);
+	SDL_Quit();
+}
