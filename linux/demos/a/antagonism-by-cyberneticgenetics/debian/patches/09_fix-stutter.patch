+/* Upload the whole CPU vertex array to the GPU using buffer orphaning:
+ * glBufferData(NULL) discards the old backing store so the GPU can keep
+ * using it for in-flight draw calls while we write to the fresh one.
+ * This eliminates the pipeline stall that glMapBuffer would cause. */
+void flushBigCube(BigCube *bc){
+	GLsizeiptr size = sizeof(GLfloat) * bc->vernum;
+	glBindBuffer(GL_ARRAY_BUFFER, bc->vbo[0]);
+	glBufferData(GL_ARRAY_BUFFER, size, NULL,          GL_DYNAMIC_DRAW);
+	glBufferSubData(GL_ARRAY_BUFFER, 0, size, bc->vertices);
 	glBindBuffer(GL_ARRAY_BUFFER, 0);
 }
