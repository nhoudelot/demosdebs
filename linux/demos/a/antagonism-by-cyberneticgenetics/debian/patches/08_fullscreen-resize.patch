+/**
+ * Update the second-pass (screen) viewport to match the new window size
+ * while preserving the original aspect ratio (letterbox / pillarbox).
+ * The FBO (fviewport) is intentionally left untouched.
+ *
+ * @param renderer  Renderer to update
+ * @param win_w     New window width  (from SDL_GetWindowSize / resize event)
+ * @param win_h     New window height
+ * @param aspect    Original aspect ratio (width/height)
+ */
+void updateViewport(Renderer *renderer, int win_w, int win_h, float aspect){
+    int draw_w, draw_h;
+
+    /* Try to fit the full window width first */
+    draw_w = win_w;
+    draw_h = (int)((float)win_w / aspect);
+
+    /* If that overflows the window height, fit by height instead */
+    if(draw_h > win_h){
+        draw_h = win_h;
+        draw_w = (int)((float)win_h * aspect);
+    }
+
+    renderer->vviewport[0] = (win_w - draw_w) / 2;   /* x: centre horizontalement */
+    renderer->vviewport[1] = (win_h - draw_h) / 2;   /* y: centre verticalement   */
+    renderer->vviewport[2] = draw_w;
+    renderer->vviewport[3] = draw_h;
+}
