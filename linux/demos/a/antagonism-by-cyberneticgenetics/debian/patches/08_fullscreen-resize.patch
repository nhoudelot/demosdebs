+void ToggleFullscreen(void){
+    static int is_fullscreen = 0;
+    is_fullscreen ^= 1;
+    SDL_SetWindowFullscreen(cg_window,
+        is_fullscreen ? SDL_WINDOW_FULLSCREEN_DESKTOP : 0);
+    /* SDL will emit SDL_WINDOWEVENT_SIZE_CHANGED which updates cg_win_w/h
+       in BEGIN_EVENT.  We also read it immediately so the very next frame
+       already has the correct dimensions even if the event is delayed. */
+    SDL_GetWindowSize(cg_window, &cg_win_w, &cg_win_h);
+}
