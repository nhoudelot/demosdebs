+static void print_usage(const char *prog){
+    fprintf(stderr,
+        "Usage: %s [WxH]\n"
+        "  e.g. %s 1920x1080\n"
+        "Default: 1280x720 (windowed)\n",
+        prog, prog);
+}
+
+int cgDialog(int argc, char *argv[], int *w, int *h, int *f){
+    *w = 1280;
+    *h =  720;
+    *f = CG_WINDOW;
+
+    if(argc >= 2){
+        if(strcmp(argv[1], "--help") == 0 || strcmp(argv[1], "-h") == 0){
+            print_usage(argv[0]);
+            return CG_QUIT;
+        }
+        char *sep = strchr(argv[1], 'x');
+        if(!sep){
+            fprintf(stderr, "Bad resolution '%s'\n", argv[1]);
+            print_usage(argv[0]);
+            return CG_QUIT;
+        }
+        *w = atoi(argv[1]);
+        *h = atoi(sep + 1);
+    }
+
+    if(*w <= 0 || *h <= 0){
+        fprintf(stderr, "Invalid resolution %dx%d\n", *w, *h);
+        return CG_QUIT;
+    }
 
