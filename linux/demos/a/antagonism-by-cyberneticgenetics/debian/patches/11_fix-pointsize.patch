This patch header follows DEP-3: http://dep.debian.net/deps/dep3/
--- a/src/antagonism.c
+++ b/src/antagonism.c
@@ -55,6 +55,11 @@
 	glEnable(GL_DEPTH_TEST);
 	glEnable(GL_BLEND);
 	glBlendFunc(GL_SRC_ALPHA,GL_ONE_MINUS_SRC_ALPHA);
+	/* In Core Profile the vertex shader's gl_PointSize writes are only
+	   honoured when GL_PROGRAM_POINT_SIZE is enabled.  Without it the
+	   fixed default (1.0) is used regardless of the pointsize uniform,
+	   making all point-cloud particles appear as single pixels. */
+	glEnable(GL_PROGRAM_POINT_SIZE);
 
 	perspectiveMatrix(pmatrix, 35.0, ASPECT, 0.1, 1500.0);
 }
