This patch header follows DEP-3: http://dep.debian.net/deps/dep3/
--- a/src/antagonism.c
+++ b/src/antagonism.c
@@ -47,6 +47,7 @@
 GLuint travis;
 GLuint shamen;
 GLuint endtitle;
+GLuint notex; /* 1x1 transparent placeholder (core profile: texture 0 is invalid) */
 /* OpenGL related initialization */
 void initOpenGL(){
 
@@ -107,6 +108,21 @@
 	shamen   = loadPNGTexture("/usr/share/antagonism-by-cyberneticgenetics/data/shamen.png");
 	endtitle = loadPNGTexture("/usr/share/antagonism-by-cyberneticgenetics/data/endpic.png");
 
+	/* In OpenGL Core Profile texture name 0 is not a valid object.
+	   Binding it to a sampler produces undefined behaviour (many drivers
+	   return alpha=1, which the post shader interprets as a fully-opaque
+	   black logo, hiding the whole scene).  Use a real 1x1 RGBA(0,0,0,0)
+	   texture as a "no overlay" placeholder instead. */
+	{
+		GLubyte transparent[4] = {0, 0, 0, 0};
+		glGenTextures(1, &notex);
+		glBindTexture(GL_TEXTURE_2D, notex);
+		glTexImage2D(GL_TEXTURE_2D, 0, GL_RGBA, 1, 1, 0,
+		             GL_RGBA, GL_UNSIGNED_BYTE, transparent);
+		glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MIN_FILTER, GL_NEAREST);
+		glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MAG_FILTER, GL_NEAREST);
+	}
+
 	pointcloud = createPC(PC_NUM, 0.0);
 
 	/* Let's the play begin */
@@ -301,7 +317,7 @@
 		glBindTexture(GL_TEXTURE_2D, endtitle);
 		break;
 	default:
-		glBindTexture(GL_TEXTURE_2D, 0);
+		glBindTexture(GL_TEXTURE_2D, notex);
 	}
 	loc = glGetUniformLocation(renderer.screen_prg, "logo");
 	glUniform1i(loc, renderer.colorbuffernum+1);
@@ -323,4 +339,5 @@
 	freePC(pointcloud);
 	deleteProgram(pc_prg, 2, pc_shaders);
 	deleteProgram(bigc_prg, 2, bigc_shaders);
+	glDeleteTextures(1, &notex);
 }
