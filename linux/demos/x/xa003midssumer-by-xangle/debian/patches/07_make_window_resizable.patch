@@ -90,7 +90,7 @@
 //		xs::error.add(temp.c_str());
 //	}
 
-	int flags = 0;
+	int flags = SDL_WINDOW_RESIZABLE;
 
 	if(ogl)
 	{
@@ -111,6 +111,8 @@
