-	// Uncompress data
+	// Uncompress data (uLongf intermédiaire requis par l'API zlib)
 	char* pData = new char[m_rsizes[number]];
-	uncompress((Bytef*)pData, &m_rsizes[number], pC, (uLong)&m_csizes[number]);
-	MemFile* pMemFile = new MemFile(pData, m_rsizes[number]);
+	uLongf destLen = m_rsizes[number];
+	uncompress((Bytef*)pData, &destLen, pC, (uLong)m_csizes[number]);
+	MemFile* pMemFile = new MemFile(pData, (long)destLen);
 
 	// Cleanup and save data
 	delete pC;
