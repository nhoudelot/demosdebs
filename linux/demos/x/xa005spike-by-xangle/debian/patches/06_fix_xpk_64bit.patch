+		// Read real and compressed size (format 32 bits)
+		uint32_t rsize, csize;
+		fread(&rsize, sizeof(uint32_t), 1, pXf);
+		fread(&csize, sizeof(uint32_t), 1, pXf);
 
 #ifdef macosx
 	#if BYTE_ORDER == BIG_ENDIAN
@@ -148,22 +149,23 @@
 		throw Exception(fn, "Can't open archive " + m_archive + ".");
 
 	// Add sizes of all previous files
-	uLongf filepos = 0;
+	uint32_t filepos = 0;
 	for(int i = 0; i < number; i++)
 		filepos += m_csizes[i];
 
 	// Seek to the file we want
-	fseek(pXf, m_loc + sizeof(uLongf) + filepos, SEEK_SET);
+	fseek(pXf, m_loc + sizeof(uint32_t) + filepos, SEEK_SET);
 
 	// Read file
 	Bytef* pC = new Bytef[m_csizes[number]];
 	fread(pC, m_csizes[number], 1, pXf);
